{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "Postgres": {
        "Host": "localhost",
        "Port": 5432,
        "Database": "appdb",
        "Username": "appuser",
        "Password": "supersecret",
        "RootCertificatePath": "/run/secrets/pg-ca.crt",
        "MinPoolSize": 2,
        "MaxPoolSize": 50,
        "TimeoutSeconds": 5,
        "CommandTimeoutSeconds": 15,
        "KeepAliveSeconds": 30,
        "ApplicationName": "UniversityApp",
        "SslMode": "Disable"
    },
    "Serilog": {
        "Using": [
            "Serilog.Sinks.Console",
            "Serilog.Sinks.File",
            "Serilog.Sinks.Seq",
            "Serilog.Enrichers.Environment",
            "Serilog.Enrichers.Thread",
            "Serilog.Enrichers.Process"
        ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "System": "Warning",
                "Microsoft.AspNetCore": "Warning",
                "Microsoft.Hosting.Lifetime": "Information"
            }
        },
        "Enrich": [
            "FromLogContext",
            "WithMachineName",
            "WithThreadId",
            "WithProcessId"
        ],
        "Properties": {
            "Application": "UniversityApp"
        },
        "WriteTo": [
            {
                "Name": "Console"
            },
            {
                "Name": "File",
                "Args": {
                    "path": "logs/log-.ndjson",
                    "rollingInterval": "Day",
                    "retainedFileCountLimit": 14,
                    "rollOnFileSizeLimit": true,
                    "fileSizeLimitBytes": 10485760,
                    "shared": true,
                    "flushToDiskInterval": "00:00:01"
                }
            },
            {
                "Name": "Seq",
                "Args": {
                    "serverUrl": "http://localhost:5104"
                }
            }
        ]
    }
}
