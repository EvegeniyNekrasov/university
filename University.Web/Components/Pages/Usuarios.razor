@page "/usuarios"

<Table TItem="User" Items="Users" Title="Usuarios" RowKey="@(u => u.Id)" EnableSearchPanes="true"
       EnableSearchPaneSearch="true" SearchPanesCascade="true" SearchPanesViewTotal="true" SearchPanesColumns="3"
       EnableColumnFilters="true" EnableMultiSort="true" SearchDebounceMs="300" RowsClickable="true"
       IsRowClickable="@(u => u.IsActive)" OnRowClick="OnUserClicked"
       RowCssClass="@(u => u.IsActive ? "" : "table-row-disabled")" ExpandOnRowClick="false"
       AllowMultipleExpandedRows="true" IsRowExpandable="@(u => true)" ShowSelection="false" MultipleSelection="false"
       SelectedItemsChanged="OnSelectionChanged" SearchPanesInitialCollapsed="false" ShowExportButton="true"
       CsvFileName="usuarios.csv" ExportMode="TableExportMode.Filtered" ShowColumnVisibilityButton="true"
       StickyHeader="true" MaxHeight="620px" ResponsiveCards="true" PersistState="true" StateKey="users-table">

    <ToolbarActions>
        <button class="btn-mini primary" @onclick="CreateUser">
            Nuevo usuario
        </button>
        <button class="btn-mini warning" @onclick="@(() => Console.WriteLine("otra cosa"))">
            Otra cosa
        </button>
        <button class="btn-mini secondary" @onclick="@(() => Console.WriteLine("oleee"))">
            Oleee
        </button>
    </ToolbarActions>

    
    <EmptyTemplate>
        <div>
            <strong>No hay usuarios.</strong>
            <div>Prueba a limpiar los filtros.</div>
        </div>
    </EmptyTemplate>

    <RowDetails Context="u">
        <div class="user-details">
            <div>
                <strong>ID:</strong> @u.Id
            </div>
            <div>
                <strong>Email:</strong> @u.Email
            </div>
            <div>
                <strong>Fecha de alta:</strong> @u.CreatedAt.ToString("dd/MM/yyyy")
            </div>
            <div>
                <strong>Notas:</strong> @u.Notes
            </div>
        </div>
    </RowDetails>

    <RowActions Context="u">
        <button class="btn-mini primary" @onclick="() => EditUser(u)">
            Editar
        </button>
        
        <button class="btn-mini success" @onclick="() => DeleteUser(u)">
            Warning
        </button>

        <button class="btn-mini danger" @onclick="() => DeleteUser(u)">
            Eliminar
        </button>
    </RowActions>

    <ChildContent>
        <TableColumn TItem="User" Key="name" Title="Nombre" Value="@(u => u.Name)" SearchPane="false"
                     ShowColumnFilter="false" ColumnFilterPlaceholder="Buscar nombre..." />

        <TableColumn TItem="User" Key="email" Title="Email" Value="@(u => u.Email)" SearchPane="false"
                     ShowColumnFilter="false" />

        <TableColumn TItem="User" Key="role" Title="Rol" Value="@(u => u.Role)" SearchPane="true"
                     FilterType="TableFilterType.Select" FilterOptions="RoleOptions" ShowColumnFilter="false" />

        <TableColumn TItem="User" Key="createdAt" Title="Alta" Value="@(u => u.CreatedAt)" SearchPane="true"
                     SearchPaneTitle="Año" SearchPaneValue="@(u => u.CreatedAt.Year.ToString())"
                     FilterType="TableFilterType.DateRange" ShowColumnFilter="false">
            <Template Context="u">
                @u.CreatedAt.ToString("dd/MM/yyyy")
            </Template>
        </TableColumn>

        <TableColumn TItem="User" Key="isActive" Title="Activo" Value="@(u => u.IsActive)" SearchPane="true"
                     FilterType="TableFilterType.Boolean" ShowColumnFilter="false"
                     ExportValue='@(u => u.IsActive ? "Activo" : "Inactivo")'>
            <Template Context="u">
                <span class="badge @(u.IsActive ? "ok" : "off")">
                    @(u.IsActive ? "Activo" : "Inactivo")
                </span>
            </Template>
        </TableColumn>
    </ChildContent>
</Table>

<style>
    .badge {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: .25rem .65rem;
        font-size: .8rem;
        font-weight: 700;
    }

    .badge.ok {
        background: #d1e7dd;
        color: #0f5132;
    }

    .badge.off {
        background: #f8d7da;
        color: #842029;
    }

    .table-row-disabled {
        opacity: .6;
    }

    .user-details {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: .75rem 1.25rem;
        font-size: .925rem;
    }

    .btn-mini {
        border: 0;
        border-radius: .45rem;
        padding: .35rem .6rem;
        font-size: .8rem;
        font-weight: 700;
        cursor: pointer;
        margin-left: .35rem;
    }

    .btn-mini.primary {
        background: #0d6efd;
        color: white;
    }

    .btn-mini.danger {
        background: #dc3545;
        color: white;
    }

    @@media (max-width: 768px) {
        .user-details {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private IReadOnlyList<TableFilterOption> RoleOptions = new[]
    {
        new TableFilterOption("Admin", "Admin"),
        new TableFilterOption("Manager", "Manager"),
        new TableFilterOption("User", "User")
    };

    private List<User> Users = new()
    {
        new(1, "Ana García", "ana@app.com", "Admin", new DateTime(2024, 1, 12), true, "Tiene permisos completos."),
        new(2, "Luis Pérez", "luis@app.com", "User", new DateTime(2024, 3, 4), true, "Usuario estándar."),
        new(3, "Marta López", "marta@app.com", "Manager", new DateTime(2023, 11, 22), false, "Cuenta desactivada temporalmente."),
        new(4, "Carlos Ruiz", "carlos@app.com", "User", new DateTime(2025, 2, 18), true, "Pendiente de revisar perfil."),
        new(5, "Lucía Torres", "lucia@app.com", "Manager", new DateTime(2025, 6, 8), true, "Responsable de equipo."),
        new(6, "Pedro Molina", "pedro@app.com", "User", new DateTime(2024, 9, 2), false, "Sin actividad reciente.")
    };

    private Task OnUserClicked(User user)
    {
        Console.WriteLine($"Click en usuario: {user.Name}");
        return Task.CompletedTask;
    }

    private Task OnSelectionChanged(IReadOnlyList<User> selectedUsers)
    {
        Console.WriteLine($"Seleccionados: {selectedUsers.Count}");
        return Task.CompletedTask;
    }

    private void CreateUser()
    {
        Console.WriteLine("Nuevo usuario");
    }

    private void EditUser(User user)
    {
        Console.WriteLine($"Editar: {user.Name}");
    }

    private void DeleteUser(User user)
    {
        Console.WriteLine($"Eliminar: {user.Name}");
    }

    private record User(
        int Id,
        string Name,
        string Email,
        string Role,
        DateTime CreatedAt,
        bool IsActive,
        string Notes);
}