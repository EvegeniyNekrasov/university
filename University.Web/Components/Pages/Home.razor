@page "/"
@using Microsoft.AspNetCore.Authorization
@using University.Web.Components.UiComponents.Charts
@attribute [Authorize]

<PageTitle>Home</PageTitle>

<h1>University app</h1>

this is my university app

<MudAvatar Color="Color.Primary">M</MudAvatar>

<PieChart Title="Distribución de tráfico" SeriesName="Canales" Data="@data" Options="@options3" />

<Chart Title="Ventas por canal" Categories="@months" Series="@series" Options="@options" />

<Chart Title="Mix de canales" Categories="@months" Series="@series" Options="@options2" />

@code {
    private readonly List<string> months = ["Ene", "Feb", "Mar", "Abr"];
    private readonly University.Web.Components.UiComponents.Charts.PieChartOptions options3 = new()
    {
        Height = "420px",
        InnerSize = "60%",
        ShowLegend = true,
        ShowDataLabels = true,
        TooltipValueSuffix = "%",
        Colors = ["#3b82f6", "#10b981", "#f59e0b", "#ef4444"]
