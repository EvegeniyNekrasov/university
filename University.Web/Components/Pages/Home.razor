    private readonly List<PiePoint> data =
    [
        new() { Name = "Orgánico", Y = 42m, Sliced = true, Selected = true },
        new() { Name = "Pago", Y = 26m },
        new() { Name = "Social", Y = 18m },
        new() { Name = "Referral", Y = 14m }
    ];
    private readonly University.Web.Components.UiComponents.Charts.ChartOptions options = new()
    {
        Type = "column",
        Height = "420px",
        Subtitle = "Stacked normal",
        YAxisTitle = "€",
        Stacking = ChartStackingMode.Normal,
        EnableDataLabels = true,
        TooltipValuePrefix = "€"
    };

    private readonly University.Web.Components.UiComponents.Charts.ChartOptions options2 = new()
    {
        Type = "column",
        Height = "420px",
        Subtitle = "Stacked percent",
        YAxisTitle = "%",
