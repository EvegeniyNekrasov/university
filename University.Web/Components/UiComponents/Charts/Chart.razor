@inherits HighchartsComponentBase

<div id="@ContainerId" class="@Class" style="width:100%; height:@ResolvedHeight;"></div>


@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Class { get; set; }

    [Parameter] public IReadOnlyList<string>? Categories { get; set; }
    [Parameter] public IReadOnlyList<ChartSeries> Series { get; set; } = [];

    [Parameter] public ChartOptions Options { get; set; } = new();

    private string ResolvedHeight => Options?.Height ?? "400px";

    protected override string ModulePath => "./Components/UiComponents/Charts/Chart.razor.js";

    protected override object BuildConfig()
    {
        var options = Options ?? new ChartOptions();

        return new
        {
            title = Title,
            subtitle = options.Subtitle,
            type = options.Type,
            heightPx = ParseHeightPx(options.Height),
            categories = Categories,

            xAxisTitle = options.XAxisTitle,
            xAxisLabelsRotation = options.XAxisLabelsRotation,

            yAxisTitle = options.YAxisTitle,
            yAxisMin = options.YAxisMin,
            yAxisMax = options.YAxisMax,

            showLegend = options.ShowLegend,
            stacking = ToHighchartsStacking(options.Stacking),

            tooltipPointFormat = options.TooltipPointFormat,
            tooltipValuePrefix = options.TooltipValuePrefix,
            tooltipValueSuffix = options.TooltipValueSuffix,

            colors = options.Colors,
            enableDataLabels = options.EnableDataLabels,

            series = Series.Select(s => new
            {
                name = s.Name,
                type = s.Type,
                stack = s.Stack,
                color = s.Color,
                visible = s.Visible,
                data = s.Data
            }).ToList()
        };
    }
}